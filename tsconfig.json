{
  "compilerOptions": {
    "target": "ESNext",
    "jsx": "preserve",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "declaration": true,
    "declarationDir": "dist/types",
    "noEmit": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["docs/**/*.ts", "docs/**/*.vue"],
  "exclude": ["node_modules", ".vitepress/.temp", ".vitepress/dist", ".vitepress/cache"]
}
