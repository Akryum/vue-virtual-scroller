{
  "name": "vue-virtual-scroller",
  "type": "module",
  "version": "3.0.0",
  "description": "Smooth scrolling for any amount of data",
  "author": {
    "name": "Guillaume Chau",
    "email": "guillaume.b.chau@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/Akryum/vue-virtual-scroller#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Akryum/vue-virtual-scroller.git"
  },
  "bugs": {
    "url": "https://github.com/Akryum/vue-virtual-scroller/issues"
  },
  "keywords": [
    "vue",
    "vuejs",
    "plugin"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vue-virtual-scroller.js",
      "default": "./dist/vue-virtual-scroller.js"
    },
    "./components/DynamicScroller": {
      "types": "./dist/components/DynamicScroller.vue.d.ts",
      "import": "./dist/components/DynamicScroller.js"
    },
    "./components/DynamicScrollerItem": {
      "types": "./dist/components/DynamicScrollerItem.vue.d.ts",
      "import": "./dist/components/DynamicScrollerItem.js"
    },
    "./components/RecycleScroller": {
      "types": "./dist/components/RecycleScroller.vue.d.ts",
      "import": "./dist/components/RecycleScroller.js"
    },
    "./components/WindowScroller": {
      "types": "./dist/components/WindowScroller.vue.d.ts",
      "import": "./dist/components/WindowScroller.js"
    },
    "./composables/useDynamicScroller": {
      "types": "./dist/composables/useDynamicScroller.d.ts",
      "import": "./dist/composables/useDynamicScroller.js"
    },
    "./composables/useDynamicScrollerItem": {
      "types": "./dist/composables/useDynamicScrollerItem.d.ts",
      "import": "./dist/composables/useDynamicScrollerItem.js"
    },
    "./composables/useIdState": {
      "types": "./dist/composables/useIdState.d.ts",
      "import": "./dist/composables/useIdState.js"
    },
    "./composables/useRecycleScroller": {
      "types": "./dist/composables/useRecycleScroller.d.ts",
      "import": "./dist/composables/useRecycleScroller.js"
    },
    "./composables/useTableColumnWidths": {
      "types": "./dist/composables/useTableColumnWidths.d.ts",
      "import": "./dist/composables/useTableColumnWidths.js"
    },
    "./composables/useWindowScroller": {
      "types": "./dist/composables/useWindowScroller.d.ts",
      "import": "./dist/composables/useWindowScroller.js"
    },
    "./dist/vue-virtual-scroller.css": "./dist/vue-virtual-scroller.css",
    "./index.css": "./dist/vue-virtual-scroller.css"
  },
  "module": "dist/vue-virtual-scroller.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "skills"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:package": "node ./scripts/check-package-exports.mjs",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "pnpm run lint && pnpm run typecheck && pnpm run build && pnpm run test:package",
    "lint": "cd ../../ && pnpm run lint"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^28.1.0",
    "typescript": "^5.3.3",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "4.0.16",
    "vue": "^3.5.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 8"
  ],
  "publishConfig": {
    "access": "public"
  }
}
